#!/usr/bin/env bash
set -euo pipefail

# ===== Настройки =====
PROJECT_DIR="$(cd "$(dirname "$0")" && pwd)"
APK_PATH="$PROJECT_DIR/app/build/outputs/apk/debug/app-debug.apk"
GRADLE="$PROJECT_DIR/gradlew"
ADB="adb"
PACKAGE="com.healthconnect.export"
LOCAL_EXPORT_DIR="$PROJECT_DIR/exports"

# ===== Цвета =====
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

info()  { echo -e "${CYAN}[INFO]${NC}  $*"; }
ok()    { echo -e "${GREEN}[OK]${NC}    $*"; }
warn()  { echo -e "${YELLOW}[WARN]${NC}  $*"; }
error() { echo -e "${RED}[ERROR]${NC} $*"; }

# ===== Проверка зависимостей =====
check_deps() {
    info "Проверка зависимостей..."

    if [ ! -f "$GRADLE" ]; then
        error "gradlew не найден: $GRADLE"
        exit 1
    fi

    if ! command -v "$ADB" &>/dev/null; then
        error "adb не найден. Установите Android SDK platform-tools."
        exit 1
    fi

    ok "Все зависимости на месте."
}

# ===== Сборка =====
build() {
    info "Сборка debug APK..."
    cd "$PROJECT_DIR"
    chmod +x "$GRADLE"
    "$GRADLE" assembleDebug --no-daemon 2>&1
    ok "Сборка завершена."
}

# ===== Проверка APK =====
check_apk() {
    if [ ! -f "$APK_PATH" ]; then
        error "APK не найден: $APK_PATH"
        exit 1
    fi
    local size
    size=$(du -h "$APK_PATH" | cut -f1)
    ok "APK найден: $APK_PATH ($size)"
}

# ===== Проверка устройств =====
check_device() {
    info "Поиск подключённых устройств..."
    local devices
    devices=$("$ADB" devices 2>/dev/null | grep -v "^List" | grep -v "^$" || true)

    if [ -z "$devices" ]; then
        error "Нет подключённых устройств."
        echo ""
        echo "  Подключите устройство по USB и включите отладку по USB,"
        echo "  или запустите эмулятор."
        echo ""
        echo "  Для подключения по Wi-Fi:"
        echo "    adb tcpip 5555"
        echo "    adb connect <IP_устройства>:5555"
        exit 1
    fi

    local count
    count=$(echo "$devices" | wc -l)
    ok "Найдено устройств: $count"
    echo "$devices" | while read -r line; do
        echo "  → $line"
    done
}

# ===== Установка APK =====
install_apk() {
    info "Установка APK на устройство..."
    "$ADB" install -r "$APK_PATH" 2>&1
    ok "APK установлен."
}

# ===== Запуск приложения =====
launch_app() {
    info "Запуск приложения..."
    "$ADB" shell am start -n "$PACKAGE/.MainActivity" 2>&1
    ok "Приложение запущено."
}

# ===== Выгрузка JSON =====
pull_exports() {
    info "Поиск директории экспорта на устройстве..."

    local remote_dir
    remote_dir=$("$ADB" shell "run-as $PACKAGE sh -c 'echo \\\$EXTERNAL_STORAGE/Android/data/$PACKAGE/files'" 2>/dev/null || true)

    if [ -z "$remote_dir" ] || [ "$remote_dir" = "null" ]; then
        # Fallback: ищем через find
        remote_dir=$("$ADB" shell "run-as $PACKAGE find /storage -name 'health_*.json' -maxdepth 6 2>/dev/null | head -1 | xargs dirname" 2>/dev/null || true)
    fi

    if [ -z "$remote_dir" ]; then
        # Ещё один fallback: стандартный external files dir
        remote_dir="/storage/emulated/0/Android/data/$PACKAGE/files"
    fi

    info "Целевая директория на устройстве: $remote_dir"

    mkdir -p "$LOCAL_EXPORT_DIR"

    local count
    count=$("$ADB" shell "run-as $PACKAGE ls \"$remote_dir\" 2>/dev/null | grep -c 'health_.*\.json' || true" 2>/dev/null || echo "0")

    if [ "$count" -eq 0 ] || [ -z "$count" ]; then
        # Пробуем без run-as (если файлы в общем доступе)
        info "Попытка без run-as..."
        count=$("$ADB" shell "ls \"$remote_dir\" 2>/dev/null | grep -c 'health_.*\.json' || true" 2>/dev/null || echo "0")
    fi

    if [ "$count" -eq 0 ] || [ -z "$count" ]; then
        warn "JSON-файлы не найдены в $remote_dir"
        info "Проверьте, что экспорт был выполнен в приложении."
        exit 0
    fi

    info "Найдено файлов: $count"

    # Выгружаем файлы
    "$ADB" shell "run-as $PACKAGE cp -r \"$remote_dir/health_\"*.json /data/local/tmp/ 2>/dev/null" || true
    "$ADB" pull "/data/local/tmp/health_"*.json "$LOCAL_EXPORT_DIR/" 2>/dev/null || \
    "$ADB" pull "$remote_dir/health_"*.json "$LOCAL_EXPORT_DIR/" 2>/dev/null || {
        # Последний fallback: копируем через run-as в tmp и пуллим
        "$ADB" shell "run-as $PACKAGE cp \"$remote_dir/health_\"*.json /data/local/tmp/" 2>/dev/null || true
        "$ADB" shell "chmod 644 /data/local/tmp/health_*.json" 2>/dev/null || true
        "$ADB" pull "/data/local/tmp/health_"*.json "$LOCAL_EXPORT_DIR/"
    }

    # Очищаем tmp
    "$ADB" shell "rm -f /data/local/tmp/health_*.json" 2>/dev/null || true

    local pulled
    pulled=$(ls -1 "$LOCAL_EXPORT_DIR"/health_*.json 2>/dev/null | wc -l)
    ok "Выгружено файлов: $pulled → $LOCAL_EXPORT_DIR/"
}

# ===== Справка =====
usage() {
    echo ""
    echo -e "${GREEN}╔══════════════════════════════════════╗${NC}"
    echo -e "${GREEN}║  HealthConnect Export — Build Tool   ║${NC}"
    echo -e "${GREEN}╚══════════════════════════════════════╝${NC}"
    echo ""
    echo "Использование: $0 [флаги]"
    echo ""
    echo "Флаги:"
    echo "  --run    Собрать APK, установить на устройство и запустить"
    echo "  --pull   Выгрузить JSON-файлы экспорта с устройства"
    echo ""
    echo "Без флагов — только сборка debug APK."
    echo ""
}

# ===== Главный процесс =====
main() {
    local do_run=false
    local do_pull=false

    if [ $# -eq 0 ]; then
        build
        exit 0
    fi

    while [ $# -gt 0 ]; do
        case "$1" in
            --run)
                do_run=true
                shift
                ;;
            --pull)
                do_pull=true
                shift
                ;;
            --help|-h)
                usage
                exit 0
                ;;
            *)
                error "Неизвестный флаг: $1"
                usage
                exit 1
                ;;
        esac
    done

    if $do_run; then
        echo ""
        echo -e "${GREEN}╔══════════════════════════════════════╗${NC}"
        echo -e "${GREEN}║  HealthConnect Export — Build & Run  ║${NC}"
        echo -e "${GREEN}╚══════════════════════════════════════╝${NC}"
        echo ""
        check_deps
        echo ""
        build
        echo ""
        check_apk
        echo ""
        check_device
        echo ""
        install_apk
        echo ""
        launch_app
        echo ""
        ok "Готово! 🎉"
    fi

    if $do_pull; then
        echo ""
        echo -e "${GREEN}╔══════════════════════════════════════╗${NC}"
        echo -e "${GREEN}║  HealthConnect Export — Pull Exports ║${NC}"
        echo -e "${GREEN}╚══════════════════════════════════════╝${NC}"
        echo ""
        check_device
        echo ""
        pull_exports
        echo ""
        ok "Готово! 🎉"
    fi
}

main "$@"
